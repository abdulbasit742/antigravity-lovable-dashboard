# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/lovable_dashboard

# Antigravity
ANTIGRAVITY_API_URL=https://your-antigravity-instance.com/api

# Encryption key for stored credentials (32+ chars)
ENCRYPTION_KEY=change-this-to-a-random-32-char-string

# Manus OAuth (for auth)
MANUS_CLIENT_ID=
MANUS_CLIENT_SECRET=
MANUS_REDIRECT_URI=http://localhost:3000/auth/callback

# App
NODE_ENV=development
PORT=3000
