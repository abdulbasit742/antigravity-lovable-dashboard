# Antigravity upstream. HTTPS is required in production.
ANTIGRAVITY_API_URL=
ANTIGRAVITY_TIMEOUT_MS=8000

# Explicit development-only fallback. Production startup rejects true.
ANTIGRAVITY_MOCK_MODE=false

# Operator authentication. Keep real values in Railway/environment secrets.
# Generate secret:
# node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
DASHBOARD_AUTH_SECRET=

# Generate bcrypt hash (replace the example password before running):
# node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" "replace-with-a-long-password"
DASHBOARD_ADMIN_PASSWORD_HASH=
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_SECURE=false

# Cross-origin access is unnecessary in production when client and API share an origin.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=false

NODE_ENV=development
PORT=3000
